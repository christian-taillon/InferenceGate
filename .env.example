# InferenceGate Configuration Template
# Copy this to .env and fill in your values

# --- Upstream AI Provider ---
# The base URL for your upstream LLM provider (e.g., OpenAI, Azure, or self-hosted)
LITELLM_API_BASE='https://api.openai.com/v1'
# Your secret API key for the upstream provider
LITELLM_API_KEY='sk-your-upstream-provider-key'

# --- Gateway Security ---
# The master key required by clients to connect to this InferenceGate proxy
# Use this in your client Authorization headers: "Bearer sk-inference-gate-v1"
LITELLM_MASTER_KEY='sk-inference-gate-v1'

# --- LlamaGuard Configuration ---
# The model used for probabilistic safety assessment (Phase 2)
# Supported options: openai/llama-guard3:1b, ollama/llama-guard3:8b, etc.
LLAMA_GUARD_MODEL='openai/llama-guard3:1b'

# --- Demo & UI Settings ---
# Friendly name of the model to display in the demo terminal
DEMO_MODEL_NAME='qwen3.5:35b-ctx100k'
